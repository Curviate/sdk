{
  "name": "@curviate/sdk",
  "version": "0.2.1",
  "private": false,
  "description": "TypeScript SDK for the Curviate API.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://docs.curviate.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/curviate/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/curviate/sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "src/generated/types.ts",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "node scripts/check-clean.mjs && tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:types": "node scripts/gen-types.mjs",
    "gen:types:fixture": "node scripts/gen-types.mjs --fixture",
    "check:types": "node scripts/check-types.mjs",
    "check:clean": "node scripts/check-clean.mjs",
    "verify:dist": "pnpm build && node scripts/verify-dist.mjs",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "msw": "^2.7.0",
    "openapi-typescript": "7.6.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.2"
  }
}
